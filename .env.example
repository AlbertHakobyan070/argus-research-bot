# Copy to .env and fill in. .env is gitignored.
FREELLMAPI_BASE_URL=http://127.0.0.1:3001/v1
FREELLMAPI_API_KEY=freellmapi-...        # dashboard Keys page at http://localhost:3001
TELEGRAM_BOT_TOKEN=123456:ABC...         # from @BotFather
TELEGRAM_ALLOWED_USER_ID=                # your Telegram numeric user id (bot answers only this user)

# v3 research engine (optional)
EXA_API_KEY=                             # https://dashboard.exa.ai — enables Exa neural search (free: ~1000 req/mo)
# ARGUS_EXA_MAX_CALLS=6                  # Exa calls per research run before falling back to DDGS
# ARGUS_RESEARCH_WAVES=2                 # max search/digest waves per run
# ARGUS_TOTAL_FETCH_CAP=28               # max sources fetched+digested per run
